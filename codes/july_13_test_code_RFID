#include <SPI.h>
#include <MFRC522.h>

#define SS_PIN 10
#define RST_PIN 9

MFRC522 mfrc522(SS_PIN, RST_PIN);


byte keysUID[] = {0xD1, 0x31, 0x6B, 0x06};
byte walletUID[] = {0x23, 0x4C, 0xCA, 0x06};

void setup() {
  Serial.begin(9600);
  SPI.begin();
  mfrc522.PCD_Init();

  Serial.println("Scan a tag...");
}

void loop() {

  if (!mfrc522.PICC_IsNewCardPresent())
    return;

  if (!mfrc522.PICC_ReadCardSerial())
    return;

  Serial.print("UID: ");

  for (byte i = 0; i < mfrc522.uid.size; i++) {

    Serial.print(mfrc522.uid.uidByte[i], HEX);
    Serial.print(" ");

  }

  Serial.println();

if (compareUID(mfrc522.uid.uidByte, keysUID, 4)) {
  Serial.println("Keys detected!");
  }
else if (compareUID(mfrc522.uid.uidByte, walletUID, 4)) {
  Serial.println("Wallet detected!");
  }
else {
    Serial.println("Unknown item.");
  }

  mfrc522.PICC_HaltA();
}
bool compareUID(byte scannedUID[], byte storedUID[], byte size) {

  for (byte i = 0; i < size; i++) {

    if (scannedUID[i] != storedUID[i]) {
      return false;
    }

  }

  return true;
}
