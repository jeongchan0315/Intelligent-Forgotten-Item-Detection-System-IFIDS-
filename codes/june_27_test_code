const int buzzerPin = 8;

void setup() {
  pinMode(buzzerPin, OUTPUT);
  pinMode(2, INPUT_PULLUP);
  Serial.begin(9600);
}

void loop() {
  if (digitalRead(2) == LOW) {
    digitalWrite(buzzerPin, HIGH); // Turn buzzer on
    delay(500);

    digitalWrite(buzzerPin, LOW);  // Turn buzzer off
    delay(500);
  }
}
